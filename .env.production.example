# Dormtel Production Environment Variables
# Copy this file to .env on your VPS and fill in the values

# Database credentials (REQUIRED - change these!)
POSTGRES_USER=dormtel
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=dormtel

# Application secret key (REQUIRED - generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
SECRET_KEY=CHANGE_ME_GENERATE_A_STRONG_KEY

# CORS allowed origins (comma-separated)
# Set to your domain, e.g. https://dormtel.yourdomain.com
CORS_ORIGINS=http://YOUR_VPS_IP

# API URL for the frontend build
REACT_APP_API_URL=http://YOUR_VPS_IP/api
